{
  "name": "haakco/custd-wordpress",
  "description": "WordPress plugin integration for Custd using the shared PHP SDK.",
  "type": "wordpress-plugin",
  "license": "MIT",
  "repositories": [
    {
      "type": "path",
      "url": "../sdk-php",
      "options": {
        "symlink": true
      }
    }
  ],
  "autoload": {
    "psr-4": {
      "HaakCo\\Custd\\WordPress\\": "src/"
    }
  },
  "require": {
    "php": ">=8.3",
    "haakco/custd-sdk": "^1.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0"
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "HaakCo\\Custd\\WordPress\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}
